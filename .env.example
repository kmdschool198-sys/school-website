VITE_KMD_ADMIN_EMAIL=adminkmd@web-site-kmd.firebaseapp.com
VITE_KMD_SUPER_EMAIL=jameskmd@web-site-kmd.firebaseapp.com

# Used only by npm run setup:staff-auth. Do not prefix passwords with VITE.
KMD_ADMIN_PASSWORD=change-this-strong-password
KMD_SUPER_PASSWORD=change-this-strong-password

# Download a Firebase service account JSON from Firebase Console > Project settings > Service accounts.
GOOGLE_APPLICATION_CREDENTIALS=C:/secure/path/web-site-kmd-service-account.json

# Google Sign-In:
# 1. Enable Firebase Authentication > Sign-in method > Google.
# 2. Add teacher emails as documents in Firestore collection staff_users.
#    Document ID: teacher email
#    Example fields: { "email": "teacher@example.com", "name": "ครูตัวอย่าง", "role": "teacher", "active": true }
