rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isStaff() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.role in ['owner', 'admin', 'editor', 'teacher', 'super']
          || isListedStaff()
          || request.auth.token.email in [
            'adminkmd@web-site-kmd.firebaseapp.com',
            'jameskmd@web-site-kmd.firebaseapp.com'
          ]
        );
    }

    function hasAuthEmail() {
      return request.auth != null && request.auth.token.email is string;
    }

    function isListedStaff() {
      return hasAuthEmail()
        && exists(/databases/$(database)/documents/staff_users/$(request.auth.token.email))
        && get(/databases/$(database)/documents/staff_users/$(request.auth.token.email)).data.active != false
        && get(/databases/$(database)/documents/staff_users/$(request.auth.token.email)).data.role in ['owner', 'admin', 'editor', 'teacher', 'super'];
    }

    function isStaffAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.role in ['owner', 'admin', 'super']
          || request.auth.token.email in [
            'adminkmd@web-site-kmd.firebaseapp.com',
            'jameskmd@web-site-kmd.firebaseapp.com'
          ]
          || (
            isListedStaff()
            && get(/databases/$(database)/documents/staff_users/$(request.auth.token.email)).data.role in ['owner', 'admin', 'super']
          )
        );
    }

    function isStringBetween(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validPdpaRequestCreate() {
      return request.resource.data.keys().hasOnly([
          'type',
          'requesterName',
          'contact',
          'relation',
          'detail',
          'status',
          'source',
          'path',
          'userAgent',
          'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'type',
          'requesterName',
          'contact',
          'relation',
          'detail',
          'status',
          'source',
          'createdAt'
        ])
        && request.resource.data.type in ['access', 'correct', 'delete', 'withdraw', 'breach', 'complaint', 'other']
        && isStringBetween(request.resource.data.requesterName, 1, 120)
        && isStringBetween(request.resource.data.contact, 3, 160)
        && isStringBetween(request.resource.data.relation, 1, 120)
        && isStringBetween(request.resource.data.detail, 1, 1200)
        && request.resource.data.status == 'new'
        && request.resource.data.source == 'privacy-page';
    }

    // Staff allowlist used by Google Sign-In. Document ID must match auth email.
    match /staff_users/{email} {
      allow get: if hasAuthEmail() && (email == request.auth.token.email || isStaffAdmin());
      allow list, create, update, delete: if isStaffAdmin();
    }

    // Public website content. Writes still require a real Firebase Auth staff user.
    match /posts/{documentId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /personnel/{documentId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /highlights/{documentId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /activities/{documentId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /pages/{documentId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /config/{documentId} {
      allow read: if documentId in ['school_info', 'home_assets', 'students_count', 'timetable'];
      allow write: if isStaff();
    }

    // Public result metadata contains no per-student records.
    match /result_announcements/{announcementId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Public lookup is single-document only; collection listing is staff-only.
    match /result_lookup/{lookupId} {
      allow get: if isStaff() || resource.data.visible == true;
      allow list: if isStaff();
      allow write: if isStaff();
    }

    // Sensitive school operations data.
    match /attendance/{documentId} {
      allow read, write: if isStaff();
    }

    match /log_body_metrics/{documentId} {
      allow read, write: if isStaff();
    }

    match /log_saving/{documentId} {
      allow read, write: if isStaff();
    }

    match /teacher_leaves/{documentId} {
      allow read, write: if isStaff();
    }

    match /results/{documentId} {
      allow read, write: if isStaff();
    }

    // PDPA workflow and evidence records.
    match /pdpa_requests/{documentId} {
      allow create: if validPdpaRequestCreate();
      allow read, update, delete: if isStaffAdmin();
    }

    match /pdpa_consents/{documentId} {
      allow create, update: if isStaff()
        && request.resource.data.actorUid == request.auth.uid;
      allow get: if isStaffAdmin()
        || (isStaff() && resource.data.actorUid == request.auth.uid);
      allow list, delete: if isStaffAdmin();
    }

    match /pdpa_audit_logs/{documentId} {
      allow create: if isStaff()
        && request.resource.data.actorUid == request.auth.uid;
      allow read: if isStaffAdmin();
      allow update, delete: if false;
    }

    match /pdpa_retention_reviews/{documentId} {
      allow read, write: if isStaffAdmin();
    }

    // Default: anything not explicitly public is staff-only.
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
